# ============================================
# Invoice Processor — environment variables
# ============================================
# Copy this file to .env and fill in real values. Never commit .env.

# --- AI / LLM ---
# OpenAI API key — https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here

# OpenAI model (gpt-4o-mini is cheaper and sufficient for development)
OPENAI_MODEL=gpt-4o-mini

# --- Database ---
# Local development (docker-compose):
#   DATABASE_URL=postgresql+asyncpg://invoice_user:invoice_pass@localhost:5432/invoices
#
# Neon / managed Postgres: paste whatever the dashboard gives you —
# the app auto-normalises the ``postgresql://`` prefix to
# ``postgresql+asyncpg://`` and converts ``?sslmode=require`` into
# an asyncpg-compatible ``connect_args={"ssl": "require"}``.
DATABASE_URL=postgresql://invoice_user:invoice_pass@localhost:5432/invoices

# --- Redis ---
# Local: redis://localhost:6379. Cloud Run demo doesn't need a queue —
# the PDF path requires Redis but the KSeF route + search work without it.
REDIS_URL=redis://localhost:6379

# --- Redis (idempotency layer for /invoices/ksef) ---
# Optional. Production: paste the rediss:// URL from Upstash dashboard
# (free Global database). Leave empty → IDEMPOTENCY_REDIS_URL falls
# back to REDIS_URL above (dev / CI).
# Behaviour: same (seller_nip, invoice_number) within 24h returns the
# original invoice_id with HTTP 200 OK instead of creating a duplicate.
IDEMPOTENCY_REDIS_URL=

# --- Qdrant ---
# Three shapes are supported (see app/services/vector_store.py):
#   http://localhost:6333    → server mode (docker-compose)
#   :memory:                 → in-process, ephemeral (Cloud Run — reindex
#                              from Postgres on every cold start)
#   file:///data/qdrant      → on-disk embedded (self-hosted w/ volume)
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=invoices

# --- Observability (Langfuse) ---
# Free tier: https://cloud.langfuse.com → project → settings → API keys.
# All three blank → SDK runs in disabled no-op mode; the @observe
# decorator still works but sends nothing home (CI, local dev).
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# --- Application ---
# development / staging / production
ENVIRONMENT=development

# Logging level — DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# Maximum upload size in MB
MAX_FILE_SIZE_MB=10

# --- OCR languages (tesseract codes) ---
# pol = Polish, eng = English, deu = German
OCR_LANGUAGES=pol+eng
